# ─── Firebase Client SDK (safe to expose — restricted by Firebase security rules) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Phone index hash salt ────────────────────────────────────────────────────
# Used on the client to hash phone numbers before lookup.
# Should be a random 64-char hex string. DIFFERENT from OTP_SALT.
NEXT_PUBLIC_PHONE_HASH_SALT=

# ─── Firebase Admin SDK (server-only — NEVER commit real values) ─────────────
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ─── TextBee SMS Gateway ──────────────────────────────────────────────────────
TEXTBEE_API_KEY=
TEXTBEE_DEVICE_ID=

# ─── Resend Email OTP ─────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── OTP & Session Security ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# OTP_SALT and JWT_SECRET should be DIFFERENT random values
OTP_SALT=
JWT_SECRET=
